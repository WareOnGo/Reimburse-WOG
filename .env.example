# Supabase transaction-mode pooler (port 6543) — required for serverless
DATABASE_URL=""
# Direct connection (port 5432) — used by Prisma for migrations only
DIRECT_URL=""

# Cloudflare R2 Credentials
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL="" # The public URL from R2 settings

ADMIN_EMAILS=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Resend (email notifications). RESEND_FROM must be a verified sender/domain in Resend.
RESEND_API_KEY=""
RESEND_FROM="Wareongo Reimbursements <reimbursements@yourdomain.com>"
RESEND_REPLY_TO="" # optional
APP_BASE_URL="http://localhost:3000" # used to build the "View in portal" link in emails
